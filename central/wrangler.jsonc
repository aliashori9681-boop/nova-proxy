{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "nova-central",
  "main": "worker.js",
  "compatibility_date": "2024-11-01",
  "workers_dev": true,
  "kv_namespaces": [
    { "binding": "KV", "id": "REPLACE_WITH_YOUR_KV_NAMESPACE_ID" }
  ],
  "triggers": { "crons": ["0 * * * *"] }
  // Secrets (set after deploy): ADMIN = your management password.
  // Optional var: CENTRAL_TOKEN (fallback Bearer token for instance writes).
}
